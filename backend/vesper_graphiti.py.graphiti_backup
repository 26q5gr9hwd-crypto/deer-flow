# [VESPER-35 FIX-3] Monkey-patch OpenAI client to normalize list LLM responses.
# Graphiti's ExtractedEdges(**llm_response) fails when model returns [] instead of {"edges": [...]}.
def _patch_llm_list_response():
    """Patch generate_response to normalize list LLM responses.
    
    graphiti_core.llm_client calls generate_response() which may return a raw list []
    when the LLM returns an empty JSON array. ExtractedEdges(**llm_response) then fails
    with: 'Input should be an object, input_value=[]'
    Fix: if result is a list, wrap it as {first_field_name: result}.
    """
    try:
        # Patch the base client class that implements generate_response
        from graphiti_core.llm_client.openai_base_client import BaseOpenAIClient as _Base
        if getattr(_Base, '_vesper35_patched', False):
            return
        _orig_gen = _Base.generate_response
        async def _safe_generate_response(self, messages, response_model=None, **kwargs):
            result = await _orig_gen(self, messages, response_model=response_model, **kwargs)
            if isinstance(result, list) and response_model is not None:
                fields = getattr(response_model, 'model_fields', {})
                if fields:
                    key = list(fields.keys())[0]
                    result = {key: result}
                    logger.debug(f'[VESPER-35] Normalized list LLM response -> dict key={key} len={len(result[key])}')
            return result
        _Base.generate_response = _safe_generate_response
        _Base._vesper35_patched = True
        logger.info('[VESPER-35] BaseOpenAIClient.generate_response patched: list normalization active')
    except Exception as _pe:
        logger.warning(f'[VESPER-35] Could not patch OpenAI base client: {_pe}')
        # Fallback: try patching OpenAIClient directly
        try:
            from graphiti_core.llm_client.openai_client import OpenAIClient as _OAI
            if getattr(_OAI, '_vesper35_patched', False):
                return
            _orig2 = _OAI.generate_response
            async def _safe_gen2(self, messages, response_model=None, **kwargs):
                result = await _orig2(self, messages, response_model=response_model, **kwargs)
                if isinstance(result, list) and response_model is not None:
                    fields = getattr(response_model, 'model_fields', {})
                    if fields:
                        result = {list(fields.keys())[0]: result}
                return result
            _OAI.generate_response = _safe_gen2
            _OAI._vesper35_patched = True
            logger.info('[VESPER-35] OpenAIClient.generate_response patched (fallback)')
        except Exception as _pe2:
            logger.warning(f'[VESPER-35] Fallback patch also failed: {_pe2}')

_patch_llm_list_response()

